# Supabase project settings (Project Settings > API in the Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Used only by the Supabase Edge Functions (server-side, never exposed to the browser) ---
# WhatsApp Business Cloud API (Meta) — from developers.facebook.com
WHATSAPP_ACCESS_TOKEN=your-permanent-or-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=choose-any-random-string-for-webhook-verification
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# Service role key (edge functions only, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
